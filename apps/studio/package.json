{
  "name": "zeroth-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc -b --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "generate:api": "openapi-typescript openapi/zeroth-core-openapi.json -o src/api/types.gen.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0",
    "@vue-flow/background": "^1.3",
    "@vue-flow/controls": "^1.1",
    "@vue-flow/core": "^1.48",
    "@vue-flow/minimap": "^1.5",
    "pinia": "^3.0",
    "tailwindcss": "^4.2",
    "vue": "^3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2",
    "@vitejs/plugin-vue": "^6.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "openapi-typescript": "^7.13",
    "typescript": "^5.8",
    "vite": "^6.0",
    "vitest": "^3.1",
    "vue-tsc": "^2.2"
  }
}
